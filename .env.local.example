# ============================================================
# .env.local.example — 环境变量模板
# 用途：提交到 Git，供新开发者复制为 .env.local 后填入真实值
# ============================================================
#
# 环境文件命名规范：
#   .env.local          — 本地开发环境（dev server 直接读取）
#   .env.vercel.prod    — Vercel 生产环境镜像（供对照同步）
#   .env.vercel.dev     — Vercel 预览环境镜像（供对照同步）
#
# 对应关系：
#   本地开发 → .env.local
#   远程预览 → .env.vercel.dev → vercel env pull preview
#   远程生产 → .env.vercel.prod → vercel env pull production

# PostgreSQL — 通过域名 + SSL 连接（本地/预览/生产共库）
DATABASE_URL=postgresql://postgres:<password>@db_lunara.qfxblacker.top:5432/lunara?sslmode=require

# Better Auth
BETTER_AUTH_SECRET=better-auth-secret-change-me
BETTER_AUTH_URL=http://localhost:3000

# DeepSeek
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Vercel Cron Job
CRON_SECRET=                     # Vercel Cron Job 验证密钥

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PayPal — 订阅支付
PAYPAL_CLIENT_ID=
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_WEBHOOK_ID=

# PayPal Plan IDs（在 PayPal Developer Dashboard 创建 Plan 后填入）
PAYPAL_PLAN_STARTER_MONTHLY=
PAYPAL_PLAN_STARTER_YEARLY=
PAYPAL_PLAN_PRO_MONTHLY=
PAYPAL_PLAN_PRO_YEARLY=
PAYPAL_PLAN_ULTRA_MONTHLY=
PAYPAL_PLAN_ULTRA_YEARLY=
PAYPAL_PLAN_TEST=

# 显隐控制
NEXT_PUBLIC_SHOW_TEST_PLAN=false
