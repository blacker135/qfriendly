# ============================================================
# QFriendly 环境变量模板
# 复制此文件为 .env.local 并根据需要填写实际值
# 标记说明：
#   ⚠️ 生产环境实际值在 Vercel 上加密，需手动填写
# ============================================================

# ---------- 数据库 ----------
# PostgreSQL 连接字符串
# 本地开发: postgresql://postgres:your_password@localhost:5432/qfriendly
# 远程访问: postgresql://postgres:your_password@db_qfriendly.qfxblacker.top:5432/qfriendly?sslmode=require
# ⚠️ Vercel Production 已配置，值加密
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/qfriendly

# ---------- Better Auth 认证 ----------
# 用于 session token 签名和加密的密钥（至少 32 字符随机字符串）
# 生成方式: openssl rand -base64 32
# ⚠️ Vercel Production 已配置，值加密
BETTER_AUTH_SECRET=your_better_auth_secret_here

# Better Auth 服务端基础 URL
# 本地开发: http://localhost:3000
# 生产环境: https://qfriendly.qfxblacker.top
# ⚠️ Vercel Production 已配置，值加密
BETTER_AUTH_URL=http://localhost:3000

# ---------- DeepSeek AI ----------
# DeepSeek API 密钥（从 platform.deepseek.com 获取）
# ⚠️ Vercel Production 已配置，值加密
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# DeepSeek API 基础地址（可选，默认官方地址 https://api.deepseek.com）
# ⚠️ Vercel Production 已配置，值加密
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ---------- 应用配置 ----------
# 应用公开访问 URL（前端可读取，用于跳转和回调）
# 本地开发: http://localhost:3000
# 生产环境: https://qfriendly.qfxblacker.top
# ⚠️ Vercel Production 已配置，值加密
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Better Auth 客户端 API 基础 URL（前端 auth client 调用认证接口使用）
# 本地开发: http://localhost:3000/api/auth
# 生产环境: https://qfriendly.qfxblacker.top/api/auth
# ⚠️ Vercel Production 已配置，值加密
NEXT_PUBLIC_AUTH_URL=http://localhost:3000/api/auth

# ---------- PayPal 支付 ----------
# PayPal REST API 客户端 ID（后端服务端调用，从 PayPal Developer Dashboard 获取）
# 格式: ARXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# ⚠️ Vercel Production 已配置，值加密
PAYPAL_CLIENT_ID=your_paypal_client_id_here

# PayPal REST API 密钥（后端服务端调用，从 PayPal Developer Dashboard 获取）
# ⚠️ Vercel Production 已配置，值加密
PAYPAL_SECRET=your_paypal_secret_here

# PayPal Webhook ID（用于验证 webhook 回调签名，从 PayPal Dashboard > Webhooks 获取）
# ⚠️ Vercel Production 已配置，值加密
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id_here

# PayPal 前端客户端 ID（前端加载 PayPal JS SDK 使用，可暴露给浏览器）
# 通常与 PAYPAL_CLIENT_ID 相同
# ⚠️ Vercel Production 已配置，值加密
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_paypal_client_id_here

# PayPal Start 月付方案 Plan ID（QFriendly-monthly-start 9.9）
# ⚠️ Vercel Production 已配置，值加密
PAYPAL_PLAN_START_MONTHLY=P-XXXXXXXXXX0000000XXXXXXX

# PayPal Start 年付方案 Plan ID（QFriendly-annual-start 99.9）
# ⚠️ Vercel Production 已配置，值加密
PAYPAL_PLAN_START_YEARLY=P-XXXXXXXXXX0000000XXXXXXX

# PayPal Pro 月付方案 Plan ID（QFriendly-monthly-pro 19.9）
# ⚠️ Vercel Production 已配置，值加密
PAYPAL_PLAN_PRO_MONTHLY=P-XXXXXXXXXX0000000XXXXXXX

# PayPal Pro 年付方案 Plan ID（QFriendly-annual-pro 199.9）
# ⚠️ Vercel Production 已配置，值加密
PAYPAL_PLAN_PRO_YEARLY=P-XXXXXXXXXX0000000XXXXXXX

# PayPal Ultra 月付方案 Plan ID（QFriendly-monthly-ultra 39.9）
# ⚠️ Vercel Production 已配置，值加密
PAYPAL_PLAN_ULTRA_MONTHLY=P-XXXXXXXXXX0000000XXXXXXX

# PayPal Ultra 年付方案 Plan ID（QFriendly-annual-ultra 399.9）
# ⚠️ Vercel Production 已配置，值加密
PAYPAL_PLAN_ULTRA_YEARLY=P-XXXXXXXXXX0000000XXXXXXX

# PayPal 测试方案 Plan ID（仅内部测试用，0.1 美元/月）
# ⚠️ Vercel Production 已配置，值加密
PAYPAL_PLAN_TEST=P-XXXXXXXXXX0000000XXXXXXX

# ---------- 功能开关 ----------
# 是否在定价页显示测试方案（设为 true 时显示，默认 false）
# ⚠️ Vercel Production 已配置，值加密
NEXT_PUBLIC_SHOW_TEST_PLAN=false

# ---------- Vercel Cron Job ----------
# Vercel Cron Job 调用密钥（防止外部直接调用 /api/cron/cleanup）
# 生成方式: openssl rand -base64 32
# ⚠️ Vercel Production 已配置，值加密
CRON_SECRET=your_cron_secret_here

# ---------- 其他 ----------
# GitHub Personal Access Token（用于 GitHub MCP 插件，可选）
GITHUB_PERSONAL_ACCESS_TOKEN=your_github_token_here
